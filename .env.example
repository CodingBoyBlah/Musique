# Spotify API credentials. Copy this file to `.env` (project root) and fill it and PLEASE dont commit (note to self).
# Get them at https://developer.spotify.com/dashboard → your app → Settings.
#
# In the Spotify dashboard, add this EXACT Redirect URI to the app:
#   http://127.0.0.1:8888/callback
#
# these are read ONLY by the Rust backend at startup and seeded into the OS, so blame windows for lack of hot reload :3
# keyring / local DB on first run, the secret never reaches the frontend
# editing credentials in the in-app Settings page overrides these

SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
