{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Musique",
  "version": "1.1.0",
  "identifier": "dev.boyblah.musique",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Musique",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 520,
        "visible": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },

  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/CodingBoyBlah/Musique/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI2NjYzN0M2NTg4Q0I5MwpSV1NUeTRobGZHTm1BcU13MEpMWCtGVVg5MDA1T0dQVldsMUpraXVIbGVIYzVtT0c4OW5JNUxqdgo="
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "minimumSystemVersion": "10.15"
    }
  }
}
